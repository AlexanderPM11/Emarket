@using Emarket.Core.Aplication.Viewmodels.Users
@model SaveUserViewModel
@{

    ViewData["Title"] = "Nuevo usuario";
}
<div class="container-fluid">
    <div class="row row_ContCreateUsers">
        <div class="col-lg-4 col-md-6 my-3 d-flex">
            <div class="card card_Adds  h-100 w-100">
                <div class="card-header bg-dark text-light">
                    <h4>Creando un nuevo usuario</h4>
                </div>
                <div class="card-body">

                    <form method="post" asp-controller="User" asp-action="Register">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Nombre: </label>
                            <input asp-for="Name" placeholder="Name" class="form-control">
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Username" class="form-label">Nombre de usuario: </label>
                            <input asp-for="Username" placeholder="user example" class="form-control"></input>

                            <span asp-validation-for="Username" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">Contraseña: </label>
                            <input step="any" asp-for="Password" class="form-control">
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label">Confirmar Contraseña: </label>
                            <input step="any" asp-for="ConfirmPassword" class="form-control">
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Correo:</label>
                            <input asp-for="Email" placeholder="example@gmail.com"  class="form-control">

                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label">Telefono:</label>
                            <input asp-for="Phone" placeholder="000-000-0000" class="form-control">

                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>


                        <button type="submit" class="btn btn-primary">Guardar</button>
                        <a asp-controller="User" asp-action="Index" class="btn btn-warning">Volver atras</a>
                    </form>
                </div>
            </div>
            </div>
        </div>
    </div>
